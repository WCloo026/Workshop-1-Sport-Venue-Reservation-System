1-- User Table
CREATE TABLE User (
    UserID INT AUTO_INCREMENT PRIMARY KEY,
    Name VARCHAR(100) NOT NULL,
    Age INT NOT NULL,
    Gender VARCHAR(2) NOT NULL,
    Username VARCHAR(50) UNIQUE NOT NULL,
    Password VARCHAR(50) NOT NULL,
    Email VARCHAR(100) UNIQUE NOT NULL,
    Contact VARCHAR(15) NOT NULL,
    CHECK (Gender IN ('M', 'F')) -- Constraint to allow only 'M' or 'F' for Gender
);
-- Set the starting value for UserID (starting from 101)
ALTER TABLE User AUTO_INCREMENT = 101;

2-- Admin Table
CREATE TABLE Admin (
    AdminID INT AUTO_INCREMENT PRIMARY KEY,
    Admin_username VARCHAR(50) UNIQUE NOT NULL,
    Admin_password VARCHAR(200) NOT NULL
);
-- Set the starting value for AdminID (starting from 201)
ALTER TABLE Admin AUTO_INCREMENT = 201;

3--Facility Table
CREATE TABLE Facility (
    FaciID INT AUTO_INCREMENT PRIMARY KEY,  -- Unique ID for each sport venue
    Facility_code VARCHAR(10) ,                -- Code for the facility (BC, PPC, PBC, FS)
    Court_name VARCHAR(10),                   -- Court name (e.g., BC01, PPC01, etc.)
    Status ENUM('Available', 'Unvailable') NOT NULL,   -- Status of the court(Booked change to Unvailable)
    Price_per_hour DECIMAL(10, 2),            -- Price per hour for booking the court
    UNIQUE (Facility_code, Court_name)        -- Ensure no duplicate court names for the same facility
);
-- Set the starting value for SVenueID (starting from 301)
ALTER TABLE Facility AUTO_INCREMENT = 301;

4-- Reservation Table
CREATE TABLE Reservation (
    ReserveID INT AUTO_INCREMENT PRIMARY KEY,  -- Unique ID for each booking
    UserID INT,                                -- User ID from the User table (assumed to be already created)
    FaciID INT,                                -- Foreign key referencing the SportVenue table
    Booking_date DATE,                         -- Date of booking
    duration INT NOT NULL,                     -- Duration of booking (in hours, e.g., 1 hour, 2 hours)
    Start_time TIME NOT NULL,
    End_time TIME NOT NULL,
    Total_price DECIMAL(10, 2),                 -- Total price calculated based on venue and duration
    FOREIGN KEY (UserID) REFERENCES User(UserID),  -- Foreign key referencing User table (assumed to exist)
    FOREIGN KEY (FaciID) REFERENCES Facility(FaciID)  -- Foreign key referencing Facility table
);
-- Set the starting value for ReserveID (starting from 501)
ALTER TABLE Reservation AUTO_INCREMENT = 401;

5-- Payment Table
CREATE TABLE Payment (
    PaymentID INT AUTO_INCREMENT PRIMARY KEY,  -- Unique ID for each payment
    ReserveID INT,                             -- Foreign key referencing the Booking table
    Payment_date DATE NULL,                          -- Date the payment was made
    Payment_amount DECIMAL(10, 2) NOT NULL,              -- Total amount of payment
    Payment_method ENUM('Cash', 'Online Transfer') NOT NULL,  -- Payment method (Cash or Online Transfer)
    Payment_status ENUM('Paid', 'Unpaid') NOT NULL,  -- Status of payment
    FOREIGN KEY (ReserveID) REFERENCES Reservation(ReserveID)  -- Foreign key referencing Booking table
);
-- Set the starting value for PaymentID (starting from 601)
ALTER TABLE Payment AUTO_INCREMENT = 501;

6-- Feedback Table
CREATE TABLE Feedback (
    FeedbackID INT AUTO_INCREMENT PRIMARY KEY,
    UserID INT,
    SVenue_code VARCHAR(20),
    Rating INT NOT NULL CHECK (Rating BETWEEN 1 AND 5),
    Comments TEXT NULL,
    Feedback_date DATETIME NOT NULL,
    
    FOREIGN KEY (UserID) REFERENCES User(UserID)
);
-- Set the starting value for FeedbackID (starting from 701)
ALTER TABLE Feedback AUTO_INCREMENT = 601;
